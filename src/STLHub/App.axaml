<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="STLHub.App"
             xmlns:local="using:STLHub"
             xmlns:sty="using:Avalonia.Styling"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ═══════════ DARK THEME ═══════════ -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="ToolbarBg">#1F1F1F</Color>
                    <Color x:Key="SidebarBg">#181818</Color>
                    <Color x:Key="SidebarHeaderBg">#1F1F1F</Color>
                    <Color x:Key="SidebarHoverBg">#2A2D2E</Color>
                    <Color x:Key="SidebarActiveBg">#37373D</Color>
                    <Color x:Key="ContentBg">#121212</Color>
                    <Color x:Key="DetailsBg">#1F1F1F</Color>
                    <Color x:Key="CardBg">#262626</Color>
                    <Color x:Key="CardThumbnailBg">#2E2E2E</Color>
                    <Color x:Key="TagBg">#333333</Color>
                    <Color x:Key="AccentColor">#0078D4</Color>
                    <Color x:Key="AccentHoverColor">#1A8CDE</Color>
                    <Color x:Key="ToolbarBtnBg">#333333</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#444444</Color>
                    <Color x:Key="TextPrimary">#E4E4E4</Color>
                    <Color x:Key="TextSecondary">#A0A0A0</Color>
                    <Color x:Key="TextMuted">#666666</Color>
                    <Color x:Key="TextOnAccent">#FFFFFF</Color>
                    <Color x:Key="SeparatorColor">#333333</Color>
                    <Color x:Key="BadgeBg">#CC000000</Color>
                    <Color x:Key="BadgeText">#CCCCCC</Color>
                    <Color x:Key="DangerColor">#E81123</Color>
                    <Color x:Key="EditBorderColor">#0078D4</Color>
                    <Color x:Key="EditBg">#2E2E2E</Color>
                </ResourceDictionary>

                <!-- ═══════════ LIGHT THEME ═══════════ -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="ToolbarBg">#F0F0F0</Color>
                    <Color x:Key="SidebarBg">#F5F5F5</Color>
                    <Color x:Key="SidebarHeaderBg">#E8E8E8</Color>
                    <Color x:Key="SidebarHoverBg">#E0E0E0</Color>
                    <Color x:Key="SidebarActiveBg">#D0D0D0</Color>
                    <Color x:Key="ContentBg">#FAFAFA</Color>
                    <Color x:Key="DetailsBg">#F0F0F0</Color>
                    <Color x:Key="CardBg">#FFFFFF</Color>
                    <Color x:Key="CardThumbnailBg">#E8E8E8</Color>
                    <Color x:Key="TagBg">#E0E0E0</Color>
                    <Color x:Key="AccentColor">#0078D4</Color>
                    <Color x:Key="AccentHoverColor">#106EBE</Color>
                    <Color x:Key="ToolbarBtnBg">#DDDDDD</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#CCCCCC</Color>
                    <Color x:Key="TextPrimary">#1A1A1A</Color>
                    <Color x:Key="TextSecondary">#555555</Color>
                    <Color x:Key="TextMuted">#999999</Color>
                    <Color x:Key="TextOnAccent">#FFFFFF</Color>
                    <Color x:Key="SeparatorColor">#D0D0D0</Color>
                    <Color x:Key="BadgeBg">#CC000000</Color>
                    <Color x:Key="BadgeText">#EEEEEE</Color>
                    <Color x:Key="DangerColor">#E81123</Color>
                    <Color x:Key="EditBorderColor">#0078D4</Color>
                    <Color x:Key="EditBg">#FFFFFF</Color>
                </ResourceDictionary>

                <!-- ═══════════ NORD THEME ═══════════ -->
                <ResourceDictionary x:Key="{x:Static local:AppThemes.Nord}">
                    <Color x:Key="ToolbarBg">#3B4252</Color>
                    <Color x:Key="SidebarBg">#2E3440</Color>
                    <Color x:Key="SidebarHeaderBg">#3B4252</Color>
                    <Color x:Key="SidebarHoverBg">#434C5E</Color>
                    <Color x:Key="SidebarActiveBg">#4C566A</Color>
                    <Color x:Key="ContentBg">#2E3440</Color>
                    <Color x:Key="DetailsBg">#3B4252</Color>
                    <Color x:Key="CardBg">#3B4252</Color>
                    <Color x:Key="CardThumbnailBg">#434C5E</Color>
                    <Color x:Key="TagBg">#4C566A</Color>
                    <Color x:Key="AccentColor">#5E81AC</Color>
                    <Color x:Key="AccentHoverColor">#81A1C1</Color>
                    <Color x:Key="ToolbarBtnBg">#434C5E</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#4C566A</Color>
                    <Color x:Key="TextPrimary">#ECEFF4</Color>
                    <Color x:Key="TextSecondary">#D8DEE9</Color>
                    <Color x:Key="TextMuted">#4C566A</Color>
                    <Color x:Key="TextOnAccent">#ECEFF4</Color>
                    <Color x:Key="SeparatorColor">#4C566A</Color>
                    <Color x:Key="BadgeBg">#CC2E3440</Color>
                    <Color x:Key="BadgeText">#D8DEE9</Color>
                    <Color x:Key="DangerColor">#BF616A</Color>
                    <Color x:Key="EditBorderColor">#5E81AC</Color>
                    <Color x:Key="EditBg">#434C5E</Color>
                </ResourceDictionary>

                <!-- ═══════════ DRACULA THEME ═══════════ -->
                <ResourceDictionary x:Key="{x:Static local:AppThemes.Dracula}">
                    <Color x:Key="ToolbarBg">#282A36</Color>
                    <Color x:Key="SidebarBg">#21222C</Color>
                    <Color x:Key="SidebarHeaderBg">#282A36</Color>
                    <Color x:Key="SidebarHoverBg">#44475A</Color>
                    <Color x:Key="SidebarActiveBg">#6272A4</Color>
                    <Color x:Key="ContentBg">#1E1F29</Color>
                    <Color x:Key="DetailsBg">#282A36</Color>
                    <Color x:Key="CardBg">#282A36</Color>
                    <Color x:Key="CardThumbnailBg">#44475A</Color>
                    <Color x:Key="TagBg">#44475A</Color>
                    <Color x:Key="AccentColor">#BD93F9</Color>
                    <Color x:Key="AccentHoverColor">#FF79C6</Color>
                    <Color x:Key="ToolbarBtnBg">#44475A</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#6272A4</Color>
                    <Color x:Key="TextPrimary">#F8F8F2</Color>
                    <Color x:Key="TextSecondary">#BFBFBF</Color>
                    <Color x:Key="TextMuted">#6272A4</Color>
                    <Color x:Key="TextOnAccent">#F8F8F2</Color>
                    <Color x:Key="SeparatorColor">#44475A</Color>
                    <Color x:Key="BadgeBg">#CC21222C</Color>
                    <Color x:Key="BadgeText">#F8F8F2</Color>
                    <Color x:Key="DangerColor">#FF5555</Color>
                    <Color x:Key="EditBorderColor">#BD93F9</Color>
                    <Color x:Key="EditBg">#44475A</Color>
                </ResourceDictionary>

                <!-- ═══════════ SOLARIZED DARK THEME ═══════════ -->
                <ResourceDictionary x:Key="{x:Static local:AppThemes.SolarizedDark}">
                    <Color x:Key="ToolbarBg">#073642</Color>
                    <Color x:Key="SidebarBg">#002B36</Color>
                    <Color x:Key="SidebarHeaderBg">#073642</Color>
                    <Color x:Key="SidebarHoverBg">#0A4A5A</Color>
                    <Color x:Key="SidebarActiveBg">#1A5A6A</Color>
                    <Color x:Key="ContentBg">#002B36</Color>
                    <Color x:Key="DetailsBg">#073642</Color>
                    <Color x:Key="CardBg">#073642</Color>
                    <Color x:Key="CardThumbnailBg">#0A4A5A</Color>
                    <Color x:Key="TagBg">#586E75</Color>
                    <Color x:Key="AccentColor">#268BD2</Color>
                    <Color x:Key="AccentHoverColor">#2AA198</Color>
                    <Color x:Key="ToolbarBtnBg">#0A4A5A</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#586E75</Color>
                    <Color x:Key="TextPrimary">#FDF6E3</Color>
                    <Color x:Key="TextSecondary">#93A1A1</Color>
                    <Color x:Key="TextMuted">#586E75</Color>
                    <Color x:Key="TextOnAccent">#FDF6E3</Color>
                    <Color x:Key="SeparatorColor">#586E75</Color>
                    <Color x:Key="BadgeBg">#CC002B36</Color>
                    <Color x:Key="BadgeText">#93A1A1</Color>
                    <Color x:Key="DangerColor">#DC322F</Color>
                    <Color x:Key="EditBorderColor">#268BD2</Color>
                    <Color x:Key="EditBg">#0A4A5A</Color>
                </ResourceDictionary>

                <!-- ═══════════ SOLARIZED LIGHT THEME ═══════════ -->
                <ResourceDictionary x:Key="{x:Static local:AppThemes.SolarizedLight}">
                    <Color x:Key="ToolbarBg">#EEE8D5</Color>
                    <Color x:Key="SidebarBg">#FDF6E3</Color>
                    <Color x:Key="SidebarHeaderBg">#EEE8D5</Color>
                    <Color x:Key="SidebarHoverBg">#E6DFC8</Color>
                    <Color x:Key="SidebarActiveBg">#D6CFBA</Color>
                    <Color x:Key="ContentBg">#FDF6E3</Color>
                    <Color x:Key="DetailsBg">#EEE8D5</Color>
                    <Color x:Key="CardBg">#FDF6E3</Color>
                    <Color x:Key="CardThumbnailBg">#EEE8D5</Color>
                    <Color x:Key="TagBg">#EEE8D5</Color>
                    <Color x:Key="AccentColor">#268BD2</Color>
                    <Color x:Key="AccentHoverColor">#2AA198</Color>
                    <Color x:Key="ToolbarBtnBg">#E6DFC8</Color>
                    <Color x:Key="ToolbarBtnHoverBg">#D6CFBA</Color>
                    <Color x:Key="TextPrimary">#073642</Color>
                    <Color x:Key="TextSecondary">#586E75</Color>
                    <Color x:Key="TextMuted">#93A1A1</Color>
                    <Color x:Key="TextOnAccent">#FDF6E3</Color>
                    <Color x:Key="SeparatorColor">#D6CFBA</Color>
                    <Color x:Key="BadgeBg">#CCEEE8D5</Color>
                    <Color x:Key="BadgeText">#586E75</Color>
                    <Color x:Key="DangerColor">#DC322F</Color>
                    <Color x:Key="EditBorderColor">#268BD2</Color>
                    <Color x:Key="EditBg">#FDF6E3</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>