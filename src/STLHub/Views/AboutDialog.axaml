<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="STLHub.Views.AboutDialog"
        Title="Sobre o STLHub"
        Width="420" Height="460"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*, Auto" Margin="24">
        <StackPanel Grid.Row="0" Spacing="4" HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Logo -->
            <Image Source="/Assets/logo.png" Width="140" Height="100"
                   Stretch="Uniform" Margin="0,0,0,12"/>

            <!-- App Name -->
            <TextBlock Text="STLHub" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Tagline -->
            <TextBlock Text="3D Object Catalog" FontSize="13" Opacity="0.5"
                       HorizontalAlignment="Center" Margin="0,2,0,0"/>

            <!-- Version -->
            <TextBlock x:Name="VersionText" FontSize="12" Opacity="0.4"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

            <!-- Separator -->
            <Border Height="1" Background="{DynamicResource SeparatorColor}"
                    Margin="40,16" Opacity="0.5"/>

            <!-- Description -->
            <TextBlock Text="Organize, catalogue e encontre seus modelos 3D com facilidade. Suporte a arquivos STL, 3MF e OBJ."
                       FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                       Opacity="0.7" MaxWidth="320" LineHeight="20"/>

            <!-- GitHub Link -->
            <Button x:Name="GitHubLink" Click="GitHubLink_Click"
                    HorizontalAlignment="Center" Margin="0,16,0,0"
                    Background="Transparent" Cursor="Hand" Padding="8,6"
                    CornerRadius="8">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ToolbarBtnBg}"/>
                    </Style>
                </Button.Styles>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                              Width="16" Height="16" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="github.com/jalf/stlhub" FontSize="13"
                               Foreground="{DynamicResource AccentColor}"/>
                </StackPanel>
            </Button>

            <!-- Footer -->
            <TextBlock Text="MIT License · Made with ❤ for makers"
                       FontSize="11" Opacity="0.3" HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="1" Content="Fechar"
                Width="100" Padding="12,8"
                HorizontalAlignment="Center"
                CornerRadius="6"
                Click="Close_Click"/>
    </Grid>
</Window>
