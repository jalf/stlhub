<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:STLHub.ViewModels"
        xmlns:conv="using:STLHub.Converters"
        xmlns:aconv="using:Avalonia.Controls.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="STLHub.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWindowRoot"
        Icon="/Assets/avalonia-logo.ico"
        Title="STLHub"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <conv:LocalImagePathConverter x:Key="LocalImagePathConverter"/>

        <!-- Icon Geometries -->
        <StreamGeometry x:Key="FolderOpenIcon">M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V8a2 2 0 00-2-2h-4l-2-2H4z</StreamGeometry>
        <StreamGeometry x:Key="GridSmallIcon">M1 1h4v4H1zM7 1h4v4H7zM1 7h4v4H1zM7 7h4v4H7z</StreamGeometry>
        <StreamGeometry x:Key="GridMediumIcon">M1 1h5v5H1zM8 1h5v5H8zM1 8h5v5H1zM8 8h5v5H8z</StreamGeometry>
        <StreamGeometry x:Key="GridLargeIcon">M1 1h6v6H1zM9 1h6v6H9zM1 9h6v6H1zM9 9h6v6H9z</StreamGeometry>
        <StreamGeometry x:Key="SunIcon">M12 3V1m0 18v2M5.6 5.6L4.2 4.2m13.4 13.4l1.4 1.4M3 12H1m18 0h2M5.6 18.4l-1.4 1.4M18.4 5.6l1.4-1.4M16 12a4 4 0 11-8 0 4 4 0 018 0z</StreamGeometry>
        <StreamGeometry x:Key="MoonIcon">M12 3a6 6 0 009 9 9 9 0 01-9-9z</StreamGeometry>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Name="MainGrid" ColumnDefinitions="250, Auto, *, 300" RowDefinitions="Auto, *, Auto">

        <!-- ═══════════ TOOLBAR ═══════════ -->
        <Border Grid.ColumnSpan="4" Background="{DynamicResource ToolbarBg}" Padding="8,6"
                BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto, *, Auto">

                <!-- Repository -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Command="{Binding OpenRepositoryCommand}"
                            Height="32" Padding="12,0" FontSize="12"
                            Background="{DynamicResource AccentColor}" Foreground="{DynamicResource TextOnAccent}"
                            CornerRadius="6" ToolTip.Tip="Abrir ou criar repositório">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource FolderOpenIcon}" Width="14" Height="14"
                                      Foreground="{DynamicResource TextOnAccent}"/>
                            <TextBlock Text="Abrir" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding CurrentRepositoryName}" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" Opacity="0.8"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280"
                               ToolTip.Tip="{Binding CurrentRepositoryName}"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="Buscar objetos..." Width="380"
                         HorizontalAlignment="Center" CornerRadius="16" Padding="14,7"
                         FontSize="13"/>

                <!-- Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <!-- Sort ComboBox -->
                    <ComboBox ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption}"
                              DisplayMemberBinding="{Binding Label}"
                              Height="32" MinWidth="160" Padding="8,4"
                              VerticalAlignment="Center"
                              ToolTip.Tip="Ordenar"/>

                    <Border Width="1" Height="18" Background="{DynamicResource SeparatorColor}" Margin="6,0"/>

                    <!-- View Size Buttons -->
                    <Button Command="{Binding SetViewSizeCommand}" CommandParameter="Small"
                            Height="32" Width="32" Padding="0"
                            Background="Transparent" CornerRadius="6"
                            Opacity="{Binding SmallViewOpacity}"
                            ToolTip.Tip="Pequeno">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ToolbarBtnBg}"/>
                            </Style>
                        </Button.Styles>
                        <PathIcon Data="{StaticResource GridSmallIcon}" Width="14" Height="14"
                                  Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                    <Button Command="{Binding SetViewSizeCommand}" CommandParameter="Medium"
                            Height="32" Width="32" Padding="0"
                            Background="Transparent" CornerRadius="6"
                            Opacity="{Binding MediumViewOpacity}"
                            ToolTip.Tip="Médio">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ToolbarBtnBg}"/>
                            </Style>
                        </Button.Styles>
                        <PathIcon Data="{StaticResource GridMediumIcon}" Width="14" Height="14"
                                  Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                    <Button Command="{Binding SetViewSizeCommand}" CommandParameter="Large"
                            Height="32" Width="32" Padding="0"
                            Background="Transparent" CornerRadius="6"
                            Opacity="{Binding LargeViewOpacity}"
                            ToolTip.Tip="Grande">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ToolbarBtnBg}"/>
                            </Style>
                        </Button.Styles>
                        <PathIcon Data="{StaticResource GridLargeIcon}" Width="14" Height="14"
                                  Foreground="{DynamicResource TextPrimary}"/>
                    </Button>

                    <Border Width="1" Height="18" Background="{DynamicResource SeparatorColor}" Margin="6,0"/>

                    <!-- Theme Selector -->
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedThemeOption}"
                              DisplayMemberBinding="{Binding Label}"
                              Height="32" MinWidth="130" Padding="8,0"
                              VerticalContentAlignment="Center"
                              CornerRadius="6"
                              ToolTip.Tip="Selecionar tema"/>

                    <Border Width="1" Height="18" Background="{DynamicResource SeparatorColor}" Margin="6,0"/>

                    <!-- About -->
                    <Button Click="About_Click"
                            Height="32" Width="32" Padding="0"
                            Background="Transparent" CornerRadius="6"
                            ToolTip.Tip="Sobre o STLHub">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource ToolbarBtnBg}"/>
                            </Style>
                        </Button.Styles>
                        <PathIcon Data="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM6.75 7.5h2.5v5h-2.5v-5z"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SidebarBg}"
                MinWidth="180" MaxWidth="500">
            <Grid RowDefinitions="Auto, Auto, Auto, *">
                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource SidebarHeaderBg}" Padding="14,10">
                    <TextBlock Text="EXPLORADOR" FontWeight="Bold" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" LetterSpacing="1.5"/>
                </Border>

                <!-- "All Objects" -->
                <Border Grid.Row="1" Cursor="Hand" PointerPressed="AllObjects_PointerPressed"
                        Padding="14,10" Name="AllObjectsBorder"
                        Background="Transparent"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="RootCategory_DragOver"
                        DragDrop.Drop="RootCategory_Drop">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                        </Style>
                    </Border.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📦" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Todos os Objetos" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Name="AllObjectsLabel"/>
                    </StackPanel>
                </Border>

                <!-- Tags Section -->
                <Border Grid.Row="2" IsVisible="{Binding AllTags.Count}">
                    <StackPanel>
                        <Border Background="{DynamicResource SidebarHeaderBg}" Padding="14,8">
                            <TextBlock Text="TAGS" FontWeight="Bold" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}" LetterSpacing="1.5"/>
                        </Border>
                        <ListBox ItemsSource="{Binding AllTags}"
                                 SelectedItem="{Binding SelectedTag}"
                                 Background="Transparent" BorderThickness="0"
                                 MaxHeight="200"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SidebarActiveBg}"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,6" Background="Transparent">
                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                            <TextBlock Grid.Column="0" Text="🏷" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <Button Grid.Column="2"
                                                    Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).DeleteTagGlobalCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Padding="2" Margin="0"
                                                    Width="18" Height="18" CornerRadius="9"
                                                    ToolTip.Tip="Remover tag">
                                                <TextBlock Text="✕" FontSize="9" Foreground="{DynamicResource DangerColor}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Category Tree -->
                <DockPanel Grid.Row="3">
                    <Border DockPanel.Dock="Top" Padding="14,8" Background="Transparent" Cursor="Hand" PointerPressed="AddRootCategory_PointerPressed">
                        <Border.Styles>
                            <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                            </Style>
                        </Border.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="+" FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBlock Text="Nova Pasta" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TreeView Name="CategoryTree"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Background="{DynamicResource SidebarBg}"
                              BorderThickness="0"
                              Padding="0"
                              Margin="0">
                        <TreeView.Template>
                            <ControlTemplate>
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  AllowAutoHide="True"
                                                  HorizontalAlignment="Stretch">
                                        <ItemsPresenter Name="PART_ItemsPresenter"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                        Margin="{TemplateBinding Padding}"
                                                        HorizontalAlignment="Stretch" />
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </TreeView.Template>
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem" x:DataType="vm:CategoryNode">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Styles>
                        <TreeView.ItemContainerTheme>
                            <ControlTheme TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForeground}"/>
                                <Setter Property="MinHeight" Value="32"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Grid Width="{Binding $parent[ScrollViewer].Viewport.Width}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Name="PART_LayoutRoot"
                                                    Classes="TreeViewItemLayoutRoot"
                                                    Focusable="True"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="{TemplateBinding CornerRadius}"
                                                    MinHeight="{TemplateBinding MinHeight}"
                                                    HorizontalAlignment="Stretch"
                                                    TemplatedControl.IsTemplateFocusTarget="True">
                                                <Grid Name="PART_Header" ColumnDefinitions="Auto, *">
                                                    <Grid.Margin>
                                                        <MultiBinding Converter="{x:Static aconv:TreeViewItemIndentConverter.Instance}">
                                                            <Binding Path="Level" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                            <DynamicResource ResourceKey="TreeViewItemIndent"/>
                                                        </MultiBinding>
                                                    </Grid.Margin>
                                                    <Panel Name="PART_ExpandCollapseChevronContainer"
                                                           Margin="{DynamicResource TreeViewItemExpandCollapseChevronMargin}">
                                                        <ToggleButton Name="PART_ExpandCollapseChevron"
                                                                      Theme="{StaticResource FluentTreeViewExpandCollapseChevron}"
                                                                      Focusable="False"
                                                                      IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"/>
                                                    </Panel>
                                                    <ContentPresenter Name="PART_HeaderPresenter"
                                                                      Grid.Column="1"
                                                                      Focusable="False"
                                                                      Background="Transparent"
                                                                      Content="{TemplateBinding Header}"
                                                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Center"
                                                                      Margin="{TemplateBinding Padding}"/>
                                                </Grid>
                                            </Border>
                                            <ItemsPresenter Name="PART_ItemsPresenter"
                                                            Grid.Row="1"
                                                            IsVisible="{TemplateBinding IsExpanded}"
                                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                                            HorizontalAlignment="Stretch"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter>
                                <!-- Hover -->
                                <Style Selector="^ /template/ Border#PART_LayoutRoot:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                                </Style>
                                <!-- Selected -->
                                <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                                    <Setter Property="Background" Value="{DynamicResource SidebarActiveBg}"/>
                                </Style>
                                <Style Selector="^:selected:focus /template/ Border#PART_LayoutRoot">
                                    <Setter Property="Background" Value="{DynamicResource SidebarActiveBg}"/>
                                </Style>
                                <!-- Empty chevron hidden -->
                                <Style Selector="^:empty /template/ ToggleButton#PART_ExpandCollapseChevron">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>
                                <Style Selector="^:empty /template/ Panel#PART_ExpandCollapseChevronContainer">
                                    <Setter Property="Width" Value="{DynamicResource TreeViewItemExpandCollapseChevronSize}"/>
                                </Style>
                            </ControlTheme>
                        </TreeView.ItemContainerTheme>
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="vm:CategoryNode" ItemsSource="{Binding Children}">
                                    <Grid Name="CategoryItemRoot"
                                          MinHeight="32"
                                          Background="Transparent"
                                          DragDrop.AllowDrop="True"
                                          DragDrop.Drop="Category_Drop"
                                          DragDrop.DragOver="Category_DragOver"
                                          PointerPressed="Category_PointerPressed"
                                          PointerMoved="Category_PointerMoved">
                                        <!-- Display Mode -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,2"
                                                    IsVisible="{Binding !IsEditing}"
                                                    DoubleTapped="CategoryLabel_DoubleTapped">
                                            <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center"
                                                       IsVisible="{Binding IsExpanded}"/>
                                            <TextBlock Text="📁" FontSize="13" VerticalAlignment="Center"
                                                       IsVisible="{Binding !IsExpanded}"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Edit Mode -->
                                        <TextBox Text="{Binding Name, Mode=TwoWay}"
                                                 IsVisible="{Binding IsEditing}"
                                                 Background="{DynamicResource EditBg}"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource EditBorderColor}"
                                                 FontSize="13" Padding="4,2" Margin="4,2"
                                                 KeyDown="CategoryTextBox_KeyDown"
                                                 LostFocus="CategoryTextBox_LostFocus"
                                                 Name="CategoryRenameBox"/>

                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="📁 Nova Subcategoria"
                                                          Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AddSubCategoryCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="✏ Renomear"
                                                          Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).RenameCategoryCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="🗑 Excluir"
                                                          Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).DeleteCategoryCommand}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ═══════════ GRID SPLITTER ═══════════ -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" ResizeDirection="Columns"
                      Background="{DynamicResource SeparatorColor}" Cursor="SizeWestEast"/>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Border Grid.Row="1" Grid.Column="2" Background="{DynamicResource ContentBg}">
            <Panel>
                <!-- Watermark -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Opacity="0.08" IsHitTestVisible="False" Spacing="0">
                    <Image Source="/Assets/watermark.png" Width="220" Height="220"
                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                </StackPanel>
                <!-- Object Cards -->
                <ScrollViewer Padding="16">
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedObject}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBg}" Margin="4" CornerRadius="10"
                                    Width="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CardWidth}"
                                    Height="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CardHeight}"
                                    BoxShadow="0 1 4 0 #20000000"
                                    DoubleTapped="Object3D_DoubleTapped"
                                    PointerPressed="Object3D_PointerPressed"
                                    PointerMoved="Object3D_PointerMoved">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🔄 Refazer Thumbnail"
                                                  Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).RegenerateThumbnailCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="🗑 Excluir Objeto"
                                                  Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).DeleteObjectCommand}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid RowDefinitions="*, Auto">
                                    <!-- Thumbnail -->
                                    <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True"
                                            Background="{DynamicResource CardThumbnailBg}"
                                            Height="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ThumbnailHeight}">
                                        <Panel>
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource LocalImagePathConverter}}"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border Background="{DynamicResource BadgeBg}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Padding="6,2" CornerRadius="6,0,0,0">
                                                <TextBlock Text="{Binding FileType}" FontSize="10"
                                                           Foreground="{DynamicResource BadgeText}" FontWeight="Bold"/>
                                            </Border>
                                        </Panel>
                                    </Border>
                                    <!-- Name -->
                                    <StackPanel Grid.Row="1" Margin="10,6,10,8">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CardFontSize}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
            </Panel>
        </Border>

        <!-- ═══════════ DETAILS PANEL ═══════════ -->
        <Border Grid.Row="1" Grid.Column="3" Background="{DynamicResource DetailsBg}" Padding="20"
                BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1,0,0,0"
                IsVisible="{Binding SelectedObject, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid RowDefinitions="Auto, *, Auto">
                <TextBlock Grid.Row="0" Text="Detalhes" FontWeight="Bold" FontSize="18"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" Margin="0,0,0,15" Padding="0,0,10,0">
                    <StackPanel Spacing="14">
                        <!-- Thumbnail Preview -->
                        <Border CornerRadius="10" ClipToBounds="True" Background="{DynamicResource CardThumbnailBg}"
                                Height="160" Cursor="Hand" DoubleTapped="DetailThumbnail_DoubleTapped"
                                BoxShadow="0 2 8 0 #20000000">
                            <Panel>
                                <Image Source="{Binding SelectedObject.ThumbnailPath, Converter={StaticResource LocalImagePathConverter}}"
                                       Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource BadgeBg}"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Padding="8,3" CornerRadius="6,0,0,0">
                                    <TextBlock Text="{Binding SelectedObject.FileType}" FontSize="11"
                                               Foreground="{DynamicResource BadgeText}" FontWeight="Bold"/>
                                </Border>
                            </Panel>
                        </Border>

                        <TextBlock Text="Caminho" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,-8"/>
                        <TextBlock Text="{Binding SelectedObject.MainFilePath}" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>

                        <TextBlock Text="Nome" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,6,0,-8"/>
                        <TextBox Text="{Binding SelectedObject.Name, Mode=TwoWay}" CornerRadius="6"/>

                        <TextBlock Text="Descrição" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,2,0,-8"/>
                        <TextBox Text="{Binding SelectedObject.Description, Mode=TwoWay}"
                                 AcceptsReturn="True" Height="80" TextWrapping="Wrap" CornerRadius="6"/>

                        <TextBlock Text="Data de criação" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding SelectedObject.CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="13" Margin="0,0,0,2"/>

                        <TextBlock Text="Tags" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,2,0,-8"/>
                        <ItemsControl ItemsSource="{Binding ObjectTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource TagBg}" CornerRadius="12"
                                            Padding="10,4" Margin="0,0,5,5">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <Button Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).RemoveTagCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Padding="2" Margin="0"
                                                    Width="16" Height="16" CornerRadius="8">
                                                <TextBlock Text="✕" FontSize="10" Foreground="{DynamicResource DangerColor}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding NewTagName, Mode=TwoWay}" PlaceholderText="Nova tag..."
                                     Width="130" FontSize="12" CornerRadius="6" KeyDown="NewTagTextBox_KeyDown"/>
                            <Button Content="+" Command="{Binding AddTagCommand}"
                                    Background="{DynamicResource AccentColor}" Foreground="{DynamicResource TextOnAccent}"
                                    Width="32" Height="32" CornerRadius="6" FontSize="16" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource SeparatorColor}" Margin="0,6"/>

                        <TextBlock Text="Arquivos Associados" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ListBox ItemsSource="{Binding Attachments}" Background="Transparent"
                                 BorderThickness="0" MaxHeight="150"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="90" Height="100" Margin="4" DoubleTapped="Attachment_DoubleTapped" Background="Transparent">
                                        <Panel>
                                            <Border Background="{DynamicResource CardThumbnailBg}" CornerRadius="8" ClipToBounds="True">
                                                <TextBlock Text="{Binding Type}" FontSize="16" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                            </Border>
                                            <Border CornerRadius="8" ClipToBounds="True">
                                                <Image Source="{Binding FilePath, Converter={StaticResource LocalImagePathConverter}}" Stretch="UniformToFill"/>
                                            </Border>
                                        </Panel>
                                        <Border Background="{DynamicResource BadgeBg}" VerticalAlignment="Bottom"
                                                Padding="5" CornerRadius="0,0,8,8">
                                            <TextBlock Text="{Binding FilePath}" FontSize="9"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource BadgeText}"
                                                       ToolTip.Tip="{Binding FilePath}"/>
                                        </Border>
                                        <Button Command="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).RemoveAttachmentCommand}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                                Background="{DynamicResource DangerColor}"
                                                Foreground="White" Width="20" Height="20" Padding="0"
                                                FontSize="10" CornerRadius="10">
                                            <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Anexar Arquivo..." Click="AttachFile_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Background="{DynamicResource ToolbarBtnBg}" Foreground="{DynamicResource TextPrimary}"
                                CornerRadius="6" Padding="10,8"/>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Salvar Alterações" Command="{Binding SaveMetadataCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{DynamicResource AccentColor}" Foreground="{DynamicResource TextOnAccent}"
                        Padding="12" FontWeight="Bold" FontSize="14" CornerRadius="8"/>
            </Grid>
        </Border>

        <!-- Details panel watermark (when no object is selected) -->
        <Border Grid.Row="1" Grid.Column="3" Background="{DynamicResource DetailsBg}"
                BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1,0,0,0"
                IsVisible="{Binding SelectedObject, Converter={x:Static ObjectConverters.IsNull}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Opacity="0.08" IsHitTestVisible="False">
                <Image Source="/Assets/watermark.png" Width="140" Height="140"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
            </StackPanel>
        </Border>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="4" Background="{DynamicResource ToolbarBg}"
                BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="0,1,0,0"
                Padding="12,4" Height="26">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Progress indicator -->
                <ProgressBar Grid.Column="0" IsIndeterminate="True" Width="80" Height="3"
                             Margin="0,0,10,0" VerticalAlignment="Center"
                             IsVisible="{Binding IsBusy}"
                             Foreground="{DynamicResource AccentColor}"/>
                <!-- Status / Hint text -->
                <TextBlock Grid.Column="1" Name="StatusBarText"
                           Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <!-- Item count -->
                <TextBlock Grid.Column="2" FontSize="11"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} object(s)">
                            <Binding Path="Items.Count"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
