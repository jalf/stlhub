<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="STLHub.Views.WarningDialog"
        Title="Aviso"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*, Auto" Margin="24">
        <StackPanel Grid.Row="0" Spacing="12" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="⚠" FontSize="28" Foreground="#FFC107" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
            <TextBlock x:Name="MessageText" FontSize="13" Opacity="0.75" TextWrapping="Wrap"/>
        </StackPanel>

        <Button Grid.Row="1"
                Content="OK"
                HorizontalAlignment="Right"
                Width="90"
                Padding="12,8"
                Background="{DynamicResource AccentColor}"
                Foreground="{DynamicResource TextOnAccent}"
                FontWeight="Bold"
                CornerRadius="6"
                Click="Ok_Click"/>
    </Grid>
</Window>
